#include <stdlib.h>
#include <string.h>
int* smallerNumbersThanCurrent(int* nums, int numsSize, int* returnSize) {
    *returnSize = numsSize;
    int* result = (int*)malloc(numsSize * sizeof(int));
    int count[101] = {0};
    for (int i = 0; i < numsSize; i++) {
        count[nums[i]]++;
    }
    int prev_sum = 0;
    for (int i = 0; i <= 100; i++) {
        int temp = count[i];
        count[i] = prev_sum;
        prev_sum += temp;
    }
    for (int i = 0; i < numsSize; i++) {
        result[i] = count[nums[i]];
    }
    return result;
}
